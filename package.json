{
  "name": "reynard-playwright-jenkins-framework",
  "version": "1.0.0",
  "description": "Playwright TypeScript Test Automation Framework with Jenkins CI/CD",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:qa": "cross-env ENV=qa npx playwright test",
    "test:uat": "cross-env ENV=uat npx playwright test",
    "test:staging": "cross-env ENV=staging npx playwright test",
    "test:prod": "cross-env ENV=prod npx playwright test",
    "test:ci": "npx playwright test --reporter=line,allure-playwright",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:login": "npx playwright test src/tests/login.spec.ts",
    "report": "npx playwright show-report",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results",
    "clean": "rimraf ./allure-results ./allure-report ./test-results ./logs/*.log",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.ts\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.ts\" \"*.json\""
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "dotenv": "^17.3.1",
    "faker": "^6.6.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "jenkins",
    "allure"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
